# ─── Meta WhatsApp Cloud API ───────────────────────────────────
# developers.facebook.com → твоё приложение → WhatsApp → API Setup

# Phone Number ID (не номер телефона, а ID в Meta)
PHONE_NUMBER_ID=123456789012345

# Постоянный токен доступа (System User Token, не временный!)
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxx

# Любая строка — сам придумываешь, она же вводится в Meta Dashboard
WEBHOOK_VERIFY_TOKEN=arm_shoring_secret_2024

# ─── Google Sheets (CSV) ────────────────────────────────────────
# Файл → Поделиться → Опубликовать в интернете → CSV → скопировать ссылку
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/XXX/pub?output=csv

# ─── Google Drive (документы по контейнерам) ───────────────────
# 1. Создай сервисный аккаунт: console.cloud.google.com → IAM → Сервисные аккаунты
# 2. Выдай ему роль «Читатель» и скачай JSON-ключ
# 3. Открой общую папку на Drive и добавь email сервисного аккаунта как «Читатель»

# Email сервисного аккаунта (из JSON-ключа, поле "client_email")
GOOGLE_CLIENT_EMAIL=bot@your-project.iam.gserviceaccount.com

# Приватный ключ (из JSON-ключа, поле "private_key") — вставляй как одну строку с \n
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQIBA...\n-----END PRIVATE KEY-----\n

# ID общей папки на Google Drive (последняя часть URL папки)
# https://drive.google.com/drive/folders/1AbCdEfGhIjKlMnOpQrStUvWxYz → ID = 1AbCdEfGhIjKlMnOpQrStUvWxYz
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# ─── Доступ к документам ────────────────────────────────────────
# Номера телефонов через запятую (международный формат БЕЗ +)
# Только эти номера увидят кнопку «Документы»
ALLOWED_PHONES=996700123456,996555987654

# ─── Сервер ─────────────────────────────────────────────────────
PORT=3000
